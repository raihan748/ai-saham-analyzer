{
  "manifest_version": 3,
  "name": "AI Saham Analyzer",
  "version": "1.0.0",
  "description": "AI-powered stock trading assistant — real-time analysis, market insights, and intelligent trading signals right in your browser.",
  "icons": {
    "128": "icon128.png"
  },
  "permissions": [
    "activeTab",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "128": "icon128.png"
    },
    "default_title": "AI Saham Analyzer"
  }
}
